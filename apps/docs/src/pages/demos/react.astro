---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DemoReact from "../../components/DemoReact.tsx";
---

<BaseLayout
  title="React Demo | @drm/multitabs"
  description="Live demo of @drm/multitabs-react with React Router."
>
  <section class="section" style="padding-top: 4rem;">
    <div class="shell">

      <div class="demo-header" data-aos="fade-up" data-aos-once="true">
        <div class="eyebrow">Live demo</div>
        <h1 class="h2">React</h1>
        <div class="demo-copy-card glass">
          <p class="demo-desc">
            A real instance of <code>@drm/multitabs-react</code> running with
            <code>react-router-dom</code> using <code>MemoryRouter</code> so it
            doesn't affect the page URL. Navigate the links inside the shell to
            open, close, and reorder tabs.
          </p>
        </div>
        <a href="/docs/react/" class="btn" style="display:inline-flex;align-items:center;gap:0.4rem;margin-top:1rem;">
          ← Back to React docs
        </a>
      </div>

      <div class="demo-frame glass" data-aos="fade-up" data-aos-delay="80" data-aos-once="true">
        <DemoReact client:only="react" />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .demo-header {
    margin-bottom: 2rem;
  }

  .demo-desc {
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .demo-copy-card {
    max-width: 640px;
    margin-top: 0.75rem;
    padding: 1rem 1.1rem;
    border-radius: 14px;
  }

  .demo-desc code {
    background: rgba(255,255,255,0.07);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.9em;
    color: #61dafb;
  }

  .demo-frame {
    border-radius: 14px;
    overflow: visible;
    min-height: 420px;
    background: linear-gradient(180deg, rgba(10,18,34,0.9), rgba(6,12,24,0.98));
    /* No backdrop-filter here — it creates a stacking context that traps
       position:fixed portals (context menu) below page content */
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  :global(.demo-shell-wrapper .drm-multitabs) {
    font-family: system-ui, sans-serif;
    border-radius: 14px 14px 0 0;
  }

  :global(.demo-shell-wrapper .drm-multitabs__menu-card) {
    z-index: 200;
  }

  :global(.demo-shell-wrapper) {
    width: 100%;
    min-height: 420px;
    display: flex;
    flex-direction: column;
  }

  :global(.demo-page) {
    padding: 2rem;
    color: #e2e8f0;
    flex: 1;
  }

  :global(.demo-page h2) {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: #f7f9ff;
  }

  :global(.demo-page p) {
    color: #94a3b8;
    line-height: 1.6;
  }

  :global(.demo-nav) {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  :global(.demo-nav a) {
    display: inline-block;
    padding: 0.45rem 1rem;
    background: linear-gradient(180deg, #5a95c1 0%, #326776 100%);
    color: #0a1628;
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 14px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  :global(.demo-nav a:hover) {
    opacity: 0.85;
  }
</style>
