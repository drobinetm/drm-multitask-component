---
import BaseLayout from '../layouts/BaseLayout.astro'
import NowPaymentsDonationCard from '../components/NowPaymentsDonationCard.astro'

const sponsorOptions = [
  {
    label: 'GitHub Sponsors',
    description: 'Recurring sponsorship linked to the repository profile.',
    status: 'Not available yet',
  },
]

const donationWidgetUrl = 'https://nowpayments.io/embeds/donation-widget?api_key=c30dc69c-f2bd-4650-9bc3-093d8dcfc03b'
const paymentWidgetDocsUrl = 'https://nowpayments.io/payment-widget'
---

<BaseLayout
  title="Support @drobinetm/multitabs"
  description="Funding options for @drobinetm/multitabs, including GitHub Sponsors and the NOWPayments donation widget."
  currentPath="/support"
>
  <section class="section support-page">
    <div class="shell support-shell">
      <div class="support-hero">
        <div class="eyebrow">Support the work</div>
        <h1 class="headline" style="max-width: 12ch;">Support the project.</h1>
        <p class="subhead">If <code style="color:#8ad9ff; background:rgba(24, 42, 69, 0.78); border:1px solid rgba(129, 190, 255, 0.2); border-radius:0.45rem; padding:0.16rem 0.42rem; box-shadow:inset 0 0 0 1px rgba(255, 255, 255, 0.02);">@drobinetm/multitabs</code> is useful for your team, support helps cover maintenance, documentation, fixes, and new examples.</p>
      </div>

      <div class="support-grid">
        <div class="glass card support-panel">
          <div class="eyebrow">Sponsor</div>
          <div class="support-options">
            {sponsorOptions.map((option) => (
              <div class="glass card support-option">
                <strong class="support-option__title">{option.label}</strong>
                <p class="panel-copy" style="margin-bottom:0.8rem;">{option.description}</p>
                <span class="support-option__status">
                  <span class="support-option__status-dot"></span>
                  {option.status}
                </span>
              </div>
            ))}
          </div>
        </div>

        <NowPaymentsDonationCard widgetUrl={donationWidgetUrl} docsUrl={paymentWidgetDocsUrl} />
      </div>
    </div>
  </section>

  <style>
    .support-page {
      padding-top: clamp(2.8rem, 5vw, 4.6rem);
      padding-bottom: clamp(3.6rem, 6vw, 5rem);
    }

    .support-shell {
      display: grid;
      gap: 1.2rem;
    }

    .support-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: 1rem;
    }

    .support-hero {
      min-width: 0;
    }

    .support-panel {
      padding: 1.4rem;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(10, 18, 34, 0.76), rgba(6, 12, 24, 0.92));
      min-width: 0;
    }

    .support-options,
    .support-panel {
      display: grid;
      gap: 0.9rem;
    }

    .support-option__title {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 1.2rem;
    }

    .support-option__status {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      min-height: 2.5rem;
      padding: 0.8rem 1rem;
      border-radius: 14px;
      border: 1px solid rgba(245, 189, 95, 0.3);
      background: linear-gradient(180deg, rgba(80, 56, 18, 0.42), rgba(45, 31, 10, 0.5));
      color: #f5d48f;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .support-option__status-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: #f5bd5f;
      box-shadow: 0 0 12px rgba(245, 189, 95, 0.45);
    }

    @media (max-width: 980px) {
      .support-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .support-panel {
        padding: 1rem;
        border-radius: 22px;
      }

      .support-option {
        padding: 0.95rem;
      }
    }
  </style>
</BaseLayout>
