{
  "name": "drm-multitabs-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for @drobinetm/multitabs — browser-tab-style navigation component for Vue, React, and Angular applications",
  "author": "Diovi Robinet Morales",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,mjs,json,css,md,astro}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,mjs,json,css,md,astro}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.28.0",
    "prettier": "^3.2.5",
    "turbo": "^2.1.3",
    "typescript": "5.5.4",
    "vue-eslint-parser": "^9.4.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.29.3"
}
