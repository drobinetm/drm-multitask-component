{
  "name": "@drm/multitabs-vue",
  "version": "0.1.1",
  "description": "Browser-tab-style navigation component for Vue 3",
  "keywords": [
    "vue",
    "tabs",
    "navigation",
    "multitabs",
    "router",
    "vue3"
  ],
  "homepage": "https://drm-multitabs.dev/docs/vue",
  "repository": {
    "type": "git",
    "url": "https://github.com/drm-dev/multitabs",
    "directory": "packages/vue"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/style.css"
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.5.3",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2",
    "vue-tsc": "^2.0.17"
  }
}
